# Yiora 生产环境变量样例:复制为 .env 并全部替换;.env 不得提交仓库
# 密钥生成建议: openssl rand -hex 32

# 镜像(CI 发布到 GHCR;OWNER 替换为 GitHub 用户/组织,tag 用版本号避免 latest 漂移)
YIORA_IMAGE=ghcr.io/OWNER/yiora-server:1.0.0

# 域名与证书(DNS 先指向本机)
YIORA_API_DOMAIN=api.example.com
YIORA_WS_DOMAIN=ws.example.com
YIORA_ACME_EMAIL=ops@example.com

# 鉴权密钥(api 与 ws 网关共享)
YIORA_JWT_SECRET=change-me-64-hex
YIORA_INTERNAL_TOKEN=change-me-64-hex

# MySQL(容器内部网络,不暴露宿主机)
YIORA_MYSQL_ROOT_PASSWORD=change-me
YIORA_MYSQL_USER=yiora
YIORA_MYSQL_PASSWORD=change-me

# Redis
YIORA_REDIS_PASSWORD=change-me

# 邮件服务(验证码;SendGrid/阿里云邮件推送等 SMTP)
YIORA_SMTP_HOST=smtp.example.com
YIORA_SMTP_USER=noreply@example.com
YIORA_SMTP_PASSWORD=change-me
YIORA_SMTP_FROM=noreply@example.com

# 后台 IP 白名单:逗号分隔 IP/CIDR(如 10.0.0.0/8,203.0.113.7);留空=不限制
YIORA_ADMIN_IP_ALLOWLIST=
